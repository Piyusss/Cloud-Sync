# CloudVault Environment Variables

# PostgreSQL
POSTGRES_DB=cloudvault
POSTGRES_USER=cloudvault
POSTGRES_PASSWORD=cloudvault_secret
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cloudvault
SPRING_DATASOURCE_USERNAME=cloudvault
SPRING_DATASOURCE_PASSWORD=cloudvault_secret

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=cloudvault

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# JWT
JWT_SECRET=your-256-bit-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Frontend
VITE_API_URL=http://localhost:8080/api
